{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "functions": {
    "src/app/api/generate-report/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/process-report/route.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cleanup-stale",
      "schedule": "*/5 * * * *"
    }
  ]
}
