# Supabase connection
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database direct connection (for migrations)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Vercel Blob (required for direct browser uploads via /api/upload-csv)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_token

# Optional Supabase bucket flow (legacy / fallback path)
# Make sure to run supabase/migrations/003_csv_upload_bucket.sql if you use /api/get-upload-url.